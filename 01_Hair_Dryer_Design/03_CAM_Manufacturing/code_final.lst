        -74                                                                                  
        -75                                                                                  
        -76  $$ ****************************************************                         
        -77  $$ *        P A R T N O     S E C T I O N S           *                         
        -78  $$ ****************************************************                         
        -79                                                                                  
        -80  CIMFIL/ON,PARTNO                                                                
        -81  DMY=POSTF(13)     $$ PROCESS                                                    
        -82  CLPART=TEXT/CLW   $$ EXTRACT TEXT                                               
        -83  CIMFIL/OFF                                                                      
        -84                                                                                  
        -85  $$ ****************************************************                         
        -86  $$ *        M A C H I N     S E C T I O N S           *                         
        -87  $$ ****************************************************                         
        -88                                                                                  
        -89  CIMFIL/ON,MACHIN                                                                
        -90  DMY=POSTF(13)     $$ PROCESS                                                    
        -91  PPRINT/CLPART     $$ MESSAGE PARTNO                                             
        -92  INSERT/' G0 G17 G99$'                                                           
        -93  INSERT/' G90 G94$'                                                              
        -94  CIMFIL/OFF                                                                      
        -95                                                                                  
        -96                                                                                  
        -97  $$ ****************************************************                         
        -98  $$ *        L O A D T L     S E C T I O N S           *                         
        -99  $$ ****************************************************                         
       -100                                                                                  
       -101  CIMFIL/ON,LOADTL                                                                
       -102  DMY=POSTF(20)   $$ SAVE RECORD                                                  
       -103  INSERT/' G0 G49$'                                                               
       -104  DMY=POSTF(21)   $$ RETREIVE RECORD                                              
       -105  $$ ADD OFFSET NUMBER IF NOT PROGRAMMED                                          
       -106  NBEL=POSTF(5)      $$ NUMBER OF WORD                                            
       -107  IF (NBEL.EQ.4) THEN                                                             
       -108  $$ ONLY THE TOOL NUMBER HAS BEEN PROGRAMMED                                     
       -109  $$ ADD ADJUST, OFFSET NUMBER=TOOL                                               
       -110    DMY=POSTF(9,5,(ICODEF(ADJUST)))                                               
       -111    DMY=POSTF(10,6,(POSTF(7,4)))                                                  
       -112  $$ INCREASE NUMBER OF WORD                                                      
       -113    DMY=POSTF(12,6)                                                               
       -114  ENDIF                                                                           
       -115  $$ PROCESS RECORD                                                               
       -116  DMY=POSTF(13)                                                                   
       -117  CIMFIL/OFF                                                                      
       -118                                                                                  
       -119                                                                                  
       -120  $$ ****************************************************                         
       -121  $$ *        C U T C O M     S E C T I O N S           *                         
       -122  $$ ****************************************************                         
       -123  CIMFIL/ON,CUTCOM                                                                
       -124  $$ THIS FIL IS USED TO SET A DEFAULT DIAMETER OFFSET NUMBER                     
       -125  SETV=POSTF(7,4)   $$ GET THE 4TH CL WORD                                        
       -126  SETT=POSTF(6,4)   $$ GET THE TYPE OF THE 4TH CL WORD                            
       -127  NBEL=POSTF(5)     $$ NUMBER OF WORD                                             
       -128  IF(SETT.EQ.0.AND.SETV.NE.(ICODEF(OFF)).AND.NBEL.EQ.4)THEN                       
       -129  $$ DEFAULT OFFSET NUMBER TO CURRENT TOOL NUMBER                                 
       -130    DMY=POSTF(10,5,(POSTF(1,3,497)))                                              
       -131  $$ CHANGE NUMBER OF ARGUMENT                                                    
       -132    DMY=POSTF(12,5)                                                               
       -133  ENDIF                                                                           
       -134  $$ EXECUTE THE CURRENT RECORD (MODIFIED OR NOT``)                               
       -135  DMY=POSTF(13)                                                                   
       -136  CIMFIL/OFF                                                                      
       -137                                                                                  
       -138                                                                                  
       -139  $$ ****************************************************                         
       -140  $$ *        P P R I N T     S E C T I O N S           *                         
       -141  $$ ****************************************************                         
       -142                                                                                  
       -143  CIMFIL/ON,PPRINT                                                                
       -144  $$ MACRO ON PPRINT TO IGNORE PPRINT                                             
       -145  $$ WITH THE WORD COMMENTS                                                       
       -146  MESS=TEXT/CLW                                                                   
       -147  COM=TEXT/'COMMENTS'                                                             
       -148  RSLT=INDXF(MESS,COM)                                                            
       -149  IF (RSLT.EQ.0) THEN                                                             
       -150  $$ PROCESS THE PPRINT                                                           
       -151    PPRINT/MESS                                                                   
       -152  ENDIF                                                                           
       -153  CIMFIL/OFF                                                                      
       -154                                                                                  
       -155                                                                                  
       -156  $$ ****************************************************                         
       -157  $$ *        F I N I     S E C T I O N S               *                         
       -158  $$ ****************************************************                         
       -159                                                                                  
       -160  CIMFIL/ON,14        $$ FINI STATEMENT                                           
       -161  DMY=POSTF(20)       $$ SAVE THE CURRENT RECORD                                  
       -162  AUXFUN/30           $$ OUTPUT M30                                               
       -163  DMY=POSTF(21)       $$ RECAL SAVED RECORD                                       
       -164  DMY=POSTF(13)       $$ PROCESS THE RECORD                                       
       -165  CIMFIL/OFF                                                                      
       -166  INCLUD/UNCMIL.F00                                                               
